# MongoDB Configuration
MONGO_URI=mongodb://root:example@localhost:27017
MONGO_USER=root
MONGO_PASS=example
MONGO_HOST=localhost
MONGO_PORT=27017

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama Configuration
OLLAMA_HOST=localhost:11434

# Groq API
GROQ_API_KEY=your_groq_api_key_here

# T5 Bias Detector
T5_PORT=1337
BIAS_MODEL_PATH=./bias-detector-output
BIAS_BASE_MODEL=t5-large
BIAS_DEVICE=auto
BIAS_USE_HUGGINGFACE=1

# NER Service
NER_URL=http://localhost:8100/extract

# ChromaDB
CHROMA_PATH=./chroma_db

# Memgraph (optional)
MEMGRAPH_URI=bolt://localhost:7687

# Bias MCP Server (optional)
BIAS_BACKEND=ollama
BIAS_MODEL=llama3.2
BIAS_HOST=http://localhost:11434

# LLM defaults
OLLAMA_MODEL=llama3.2

# Makefile defaults
# CONDA_MP3_ENV=kokoro
# DB_ENV=db/.venv